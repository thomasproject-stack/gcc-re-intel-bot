# Copy to .env and fill in your own values. Never commit the real .env.

# ── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather.
TELEGRAM_TOKEN=
# Numeric Telegram user id allowed to drive the bot (the only chat it talks to).
TELEGRAM_USER_ID=

# ── OpenRouter (LLM editorial pipeline) ─────────────────────────────────────
# API key from https://openrouter.ai
OPENROUTER_API_KEY=
# Model slug — defaults to a low-cost model if unset.
OPENROUTER_MODEL=deepseek/deepseek-chat
# Optional referer sent to OpenRouter for attribution.
OPENROUTER_REFERER=https://github.com

# ── Local paths (optional) ──────────────────────────────────────────────────
# Where runtime state / cache / logs are written (default: ./.state next to the script).
DATA_DIR=
# Where generated infographics are written (default: ./output next to the script).
OUTPUT_DIR=
